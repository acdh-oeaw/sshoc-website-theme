{#
/**
 * @file
 * Grid override for the partners page.
 *
 * Keeps Drupal's Views row/column grid markup, but normalizes every partner
 * column to col-3 so each row renders as four equal items.
 */
#}
{%
  set classes = [
    'views-view-grid',
    options.alignment,
    'cols-' ~ options.columns,
    'clearfix',
    'arcadia-partners-grid',
  ]
%}
{%
  set row_classes = [
    options.row_class_default ? 'views-row',
    options.alignment == 'horizontal' ? 'clearfix',
  ]
%}
{%
  set col_classes = [
    options.col_class_default ? 'views-col',
    options.alignment == 'vertical' ? 'clearfix',
    'col-3',
  ]
%}

{% if title %}
  <h3>{{ title }}</h3>
{% endif %}

<div{{ attributes.addClass(classes) }}>
  {% if options.alignment == 'horizontal' %}
    {% for row in items %}
      <div class="row pb-3">
        {% for column in row.content %}
          <div{{ column.attributes.addClass(col_classes) }}>
            {{- column.content -}}
          </div>
        {% endfor %}
      </div>
    {% endfor %}
  {% else %}
    {% for column in items %}
      <div{{ column.attributes.addClass(col_classes) }}>
        {% for row in column.content %}
          <div{{ row.attributes.addClass(row_classes, options.row_class_default ? 'row-' ~ loop.index) }}>
            {{- row.content -}}
          </div>
        {% endfor %}
      </div>
    {% endfor %}
  {% endif %}
</div>
