<div class="event-box">
  <div class="event-inner">
    <div class="row">
      <div class="col-md-12">
        {% if fields.field_image is defined %}
          {{ fields.field_image.content }}
        {% endif %}
      </div>

      <div class="col-md-12">
        <div class="content clearfix">
          <br>
          <h2 class="block-event-title">{{ fields.title is defined ? fields.title.content : '' }}</h2>
          <br>
        </div>
      </div>
    </div>

    <div class="container col-md-12">
      <div class="info">
        {% if fields.body is defined %}
          {{ fields.body.content }}
        {% endif %}

        <div class="row">
          <div class="col-md-2 event-date"><i class="fa fa-calendar"></i></div>
          <div class="col-md-3 event-date">
            <span class="d">{{ fields.field_event_date is defined ? fields.field_event_date.content : '' }}</span>
            <span class="m">{{ fields.field_event_date_1 is defined ? fields.field_event_date_1.content : '' }}</span><br>
            <span class="y">{{ fields.field_event_date_2 is defined ? fields.field_event_date_2.content : '' }}</span>
            <span class="hours">{{ fields.field_event_date_3 is defined ? fields.field_event_date_3.content : '' }}</span>
          </div>

          <div class="col-md-7 event-location">
            {{ fields.field_event_location is defined ? fields.field_event_location.content : '' }}
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
