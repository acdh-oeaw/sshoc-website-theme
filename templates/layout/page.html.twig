<div class="page-wrapper">
  <header class="main-header header-style-four vers2{{ is_front ? ' front' : '' }}">
    <div class="header-top style-two">
      <div class="container nopaddingleft">
        <div class="row">
          <div class="col-md-8 nopaddingleft">
            <div class="top-left">
              <ul class="links clearfix">
                {% if top_header_message %}
                  <li><span>{{ top_header_message }}</span></li>
                {% endif %}
              </ul>
              {% if page.top_header %}
                <div class="top-header-region">{{ page.top_header }}</div>
              {% endif %}
            </div>
          </div>
          <div class="col-md-4">
            {{ page.header }}
          </div>
        </div>
      </div>
    </div>

    <div class="header-upper">
      <div class="auto-container clearfix">
        <div class="row">
          <div class="col-12 col-md-12 col-sm-12 upper-right">
            <div class="clearfix">
              <nav class="main-menu">
                <div class="navbar-header">
                  <button type="button" class="navbar-toggle" data-toggle="collapse" data-target=".navbar-collapse">
                    <span class="icon-menu-square"></span>
                  </button>
                </div>
                <div class="row">
                  <div class="collapse navbar-collapse show col-md-12 reduced">
                    {{ page.globalmenu }}
                  </div>
                </div>
              </nav>
              <i id="menumibile" class="fa fa-2x fa-bars" aria-hidden="true"></i>
            </div>
          </div>
        </div>
      </div>
    </div>
  </header>

  {% if page.slider %}
    <section class="main-slider">
      {{ page.slider }}
    </section>
  {% endif %}

  {% if page.breadcrumb %}
    <section class="page-title">
      <div class="auto-container">
        {% if page_header_title %}
          <h1 class="news-page-title">{{ page_header_title }}</h1>
        {% endif %}
        {{ page.breadcrumb }}
      </div>
    </section>
  {% endif %}

  <section class="about-section-two">
    <div class="auto-container">
      <div class="row">
        <div class="main-content {{ has_sidebar_second ? 'col-md-8' : 'col-md-12' }}">
          <a id="main-content"></a>
          {{ page.content }}
        </div>

        {% if has_sidebar_second %}
          <div class="col-md-4 sidebar">
            {{ page.sidebar_second }}
          </div>
        {% endif %}
      </div>
    </div>
  </section>

  {% if page.top_footer %}
    <div class="container">
      <div class="top_footer">
        {{ page.top_footer }}
      </div>
    </div>
  {% endif %}

  <footer class="main-footer">
    <div class="auto-container">
      {% set has_footer_columns = footer_text_column_one|trim or footer_text_column_two|trim or footer_text_column_three|trim or footer_text_column_four|trim %}
      <div class="widgets-section">
        {% if has_footer_columns %}
          <div class="row clearfix">
            <div class="big-column col-md-6 col-sm-12 col-xs-12">
              <div class="row clearfix">
                <div class="footer-column col-md-7 col-sm-6 col-xs-12">
                  <div class="footer-widget logo-widget">
                    {{ footer_text_column_one|raw }}
                  </div>
                </div>
                <div class="footer-column col-md-5 col-sm-6 col-xs-12">
                  <div class="footer-widget links-widget">
                    {{ footer_text_column_two|raw }}
                  </div>
                </div>
              </div>
            </div>
            <div class="big-column col-md-6 col-sm-12 col-xs-12">
              <div class="row clearfix">
                <div class="footer-column col-md-5 col-sm-6 col-xs-12">
                  <div class="footer-widget links-widget">
                    {{ footer_text_column_three|raw }}
                  </div>
                </div>
                <div class="footer-column col-md-7 col-sm-6 col-xs-12">
                  <div class="footer-widget newsletter-widget">
                    {{ footer_text_column_four|raw }}
                  </div>
                </div>
              </div>
            </div>
          </div>
        {% else %}
          <div class="row clearfix footer-clone-columns">
            <div class="footer-column col-lg-3 col-md-6 col-sm-12">
              <div class="footer-widget links-widget">
                <h2>About SSHOC</h2>
                <ul class="list">
                  <li><a href="/the-project">The Project</a></li>
                  <li><a href="/partners">Consortium</a></li>
                  <li><a href="/european-research-infrastructures">European Research Infrastructures</a></li>
                  <li><a href="/sshoc-eosc">SSHOC in EOSC</a></li>
                  <li><a href="/synergies">Synergies</a></li>
                  <li><a href="https://sites.google.com/cessda.eu/sshocwiki/home" target="_blank" rel="noopener">SSHOC Wiki</a></li>
                </ul>
              </div>
            </div>
            <div class="footer-column col-lg-3 col-md-6 col-sm-12">
              <div class="footer-widget links-widget">
                <h2>Marketplace</h2>
                <ul class="list">
                  <li><a href="/service-catalogue">Service Catalogue</a></li>
                  <li><a href="https://marketplace.sshopencloud.eu/" target="_blank" rel="noopener">SSH Open Marketplace Testers</a></li>
                  <li><a href="https://marketplace.sshopencloud.eu/" target="_blank" rel="noopener">Final Version</a></li>
                </ul>
              </div>
            </div>
            <div class="footer-column col-lg-3 col-md-6 col-sm-12">
              <div class="footer-widget links-widget">
                <h2>Training</h2>
                <ul class="list">
                  <li><a href="https://training-toolkit.sshopencloud.eu/" target="_blank" rel="noopener">SSH Training Discovery Toolkit</a></li>
                  <li><a href="/training/training-events">Training Events</a></li>
                  <li><a href="/training/community">SSH Training Community</a></li>
                  <li><a href="/trainers-directory">Trainers' Directory</a></li>
                </ul>
              </div>
            </div>
            <div class="footer-column col-lg-3 col-md-6 col-sm-12">
              <div class="footer-widget links-widget">
                <h2>Data Catalogues</h2>
                <ul class="list">
                  <li><a href="/data-catalogues">Data Catalogues</a></li>
                </ul>
              </div>
            </div>
          </div>
          <div class="row clearfix footer-clone-columns footer-clone-columns-second">
            <div class="footer-column col-lg-3 col-md-6 col-sm-12">
              <div class="footer-widget links-widget">
                <h2>SSHOC in Action</h2>
                <ul class="list">
                  <li><a href="/ssh-data-communities">SSHOC Data Communities</a></li>
                  <li><a href="/taxonomy/term/50">Electoral Studies</a></li>
                  <li><a href="/taxonomy/term/49">Ethnic and Migrant Minorities</a></li>
                  <li><a href="/taxonomy/term/51">Heritage Studies</a></li>
                </ul>
              </div>
            </div>
            <div class="footer-column col-lg-3 col-md-6 col-sm-12">
              <div class="footer-widget links-widget">
                <h2>Resources</h2>
                <ul class="list">
                  <li><a href="/publications/deliverables">Deliverables & Milestones</a></li>
                  <li><a href="/events">Awareness Raising Events</a></li>
                  <li><a href="/scientific-publications">Scientific Publications</a></li>
                  <li><a href="/publications/white-paper">White Papers</a></li>
                  <li><a href="/publications/posters">Posters</a></li>
                  <li><a href="/video">Videos</a></li>
                  <li><a href="/communications-kit">Communications Kit</a></li>
                </ul>
              </div>
            </div>
            <div class="footer-column col-lg-3 col-md-6 col-sm-12">
              <div class="footer-widget links-widget">
                <h2>News & Events</h2>
                <ul class="list">
                  <li><a href="/publications/deliverables">Deliverables & Milestones</a></li>
                  <li><a href="/events">Awareness Raising Events</a></li>
                  <li><a href="/scientific-publications">Scientific Publications</a></li>
                  <li><a href="/publications/white-paper">White Papers</a></li>
                  <li><a href="/publications/posters">Posters</a></li>
                  <li><a href="/video">Videos</a></li>
                  <li><a href="/communications-kit">Communications Kit</a></li>
                </ul>
              </div>
            </div>
            <div class="footer-column col-lg-3 col-md-6 col-sm-12">
              <div class="footer-widget links-widget">
                <h2>.</h2>
                <ul class="list">
                  <li><a href="/contact-us">Contact us</a></li>
                  <li><a href="/user">Log in</a></li>
                </ul>
                <div class="footer-clone-social">
                  <a href="https://www.linkedin.com" target="_blank" rel="noopener" aria-label="LinkedIn"><i class="fa fa-linkedin"></i></a>
                  <a href="https://twitter.com" target="_blank" rel="noopener" aria-label="Twitter"><i class="fa fa-twitter"></i></a>
                  <a href="https://www.youtube.com" target="_blank" rel="noopener" aria-label="YouTube"><i class="fa fa-youtube-play"></i></a>
                </div>
              </div>
            </div>
          </div>
        {% endif %}
      </div>

      <div class="footer-bottom">
        <div class="row">
          <div class="col-md-12">
            {% if text_footer|trim %}
              {{ text_footer|raw }}
            {% else %}
              <div class="row">
                <div class="col-2 col-md-1"><img style="width: 100%;" src="/sites/all/themes/arcadia/images/eu-flag.png" alt="EU flag"></div>
                <div class="col-10 col-md-11">SSHOC, "Social Sciences and Humanities Open Cloud", has received funding from the European Union's Horizon 2020 project call H2020-INFRAEOSC-04-2018, grant agreement #823782. <a href="/privacy-policy-summary">Privacy Policy and Terms of Use</a></div>
              </div>
            {% endif %}
          </div>
        </div>
        {% if text_footer_left|trim or text_footer_right|trim %}
          <div class="clearfix">
            <div class="pull-left"><div class="copyright">{{ text_footer_left }}</div></div>
            <div class="pull-right"><div class="created">{{ text_footer_right }}</div></div>
          </div>
        {% endif %}
      </div>
    </div>
  </footer>
</div>

<div class="scroll-to-top scroll-to-target" data-target="html"><span class="icon fa fa-angle-double-up"></span></div>
