{#
/**
 * @file
 * Arcadia breadcrumb trail.
 */
#}
{% if breadcrumb %}
  <nav class="arcadia-breadcrumb" role="navigation" aria-labelledby="system-breadcrumb">
    <h2 id="system-breadcrumb" class="visually-hidden">{{ 'Breadcrumb'|t }}</h2>
    <ol class="arcadia-breadcrumb__list">
      {% for item in breadcrumb %}
        <li class="arcadia-breadcrumb__item">
          {% if item.url %}
            <a class="arcadia-breadcrumb__link" href="{{ item.url }}">{{ item.text }}</a>
          {% else %}
            <span class="arcadia-breadcrumb__current">{{ item.text }}</span>
          {% endif %}
        </li>
      {% endfor %}
    </ol>
  </nav>
{% endif %}
